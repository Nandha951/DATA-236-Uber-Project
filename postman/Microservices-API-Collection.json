{
    "info": {
        "_postman_id": "microservices-api-collection",
        "name": "Microservices API Collection",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "description": "Test all microservices APIs: User, Driver, Ride, Payment. Set `userBaseUrl`, `driverBaseUrl`, `rideBaseUrl`, `paymentBaseUrl`, and `jwtToken` as environment variables."
    },
    "item": [
        {
            "name": "User Service",
            "item": [
                {
                    "name": "Register User",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{userBaseUrl}}/api/users/",
                            "host": [
                                "{{userBaseUrl}}"
                            ],
                            "path": [
                                "api",
                                "users"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phoneNumber\": \"1234567890\",\n  \"userType\": \"customer\"\n}"
                        },
                        "description": "Register a new user."
