# Server Configuration
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=uber_simulation_secret_key
JWT_EXPIRES_IN=24h

# MySQL Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=uber_simulation
DB_USER=root
DB_PASSWORD=password

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/uber_simulation

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_SSL=false
KAFKA_SASL=false
KAFKA_USERNAME=
KAFKA_PASSWORD=

# File Upload Configuration
MAX_FILE_SIZE=5242880 # 5MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,application/pdf
UPLOAD_DIR=uploads


ENABLE_REDIS=false
ENABLE_KAFKA=false
ENABLE_MONGODB=true
